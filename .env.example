# Copy to .env and add your keys. Never commit .env to git.
OPENAI_API_KEY=your_openai_api_key_here

# Local nail detection (run: python tool/local_nail_detect_server.py)
# iOS Simulator / same Mac: http://127.0.0.1:8765/detect
# Physical phone: http://YOUR_MAC_LAN_IP:8765/detect
NAIL_DETECT_URL=http://127.0.0.1:8765/detect

# Optional fallback only — not needed if NAIL_DETECT_URL is set
ROBOFLOW_API_KEY=your_roboflow_api_key_here
ROBOFLOW_WORKSPACE=oluwaseun-ogunmolu
ROBOFLOW_WORKFLOW_ID=general-segmentation-api-3
